# Supabase PostgreSQL
# Project Settings → Database → Connection string 에서 복사
# DATABASE_URL  : Pooled connection (포트 6543, pgbouncer) — 앱 런타임용
# DIRECT_URL    : Direct connection (포트 5432) — prisma migrate 전용
DATABASE_URL="postgresql://postgres.xxxxxxxx:[PASSWORD]@aws-0-xxxx.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxxxxx:[PASSWORD]@aws-0-xxxx.supabase.com:5432/postgres"

# Supabase Storage (이미지 업로드용)
# Project Settings → API 에서 복사
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ...service_role 키 (절대 공개 금지)"
SUPABASE_MEDIA_BUCKET="media"

ADMIN_PASSWORD="change-me"
